generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  PARENT
  ADMIN
  SUPER_ADMIN
}

enum DeviceType {
  SMART_RING
  WHOOP_BAND
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id                String          @id @default(uuid())
  email             String          @unique
  passwordHash      String?
  name              String
  avatarUrl         String?
  role              UserRole        @default(USER)
  isActive          Boolean         @default(true)
  emailVerified     Boolean         @default(false)
  appleHealthToken  String?
  googleFitToken    String?
  fcmToken          String?
  phone             String?         // mandatory for orders — collected at registration
  lastActiveAt      DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  healthProfile     HealthProfile?
  devices           Device[]
  orders            Order[]
  alerts            Alert[]
  notifications     Notification[]
  familyGroupOwned  FamilyGroup[]   @relation("FamilyOwner")
  familyMemberships FamilyMember[]  @relation("FamilyMemberUser")
  kafkaEvents       KafkaEventLog[]
  aiInteractions    AiInsightInteraction[]
  aiInsights        AiInsight[]
  aiInsightCache    AiInsightCache?
  aiQuestions       AiQuestion[]
  workoutPlans      WorkoutPlan[]
  workoutLogs       WorkoutLog[]
  meditationSessions MeditationSession[]
  broadcastsSent    BroadcastMessage[]
  supportTickets    SupportTicket[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model HealthProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  age             Int?
  dateOfBirth     DateTime?
  gender          String?
  height          Float?    // cm
  weight          Float?    // kg
  bloodType       String?
  fitnessLevel    String?
  fitnessGoal     String?
  sleepGoal       Float?    // hours
  stepsGoal       Int?      @default(10000)
  caloriesGoal    Int?      @default(500)
  workoutDays     Int?
  preferredWorkouts String[]
  dietType        String?
  alcoholFrequency String?
  smokingStatus   String?
  conditions      String[]
  emergencyContact Json?
  onboardingComplete Boolean @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("health_profiles")
}

model Device {
  id              String     @id @default(uuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceSerial    String     @unique
  deviceType      DeviceType
  deviceName      String?
  firmwareVersion String?
  batteryLevel    Int?
  isActive        Boolean    @default(true)
  lastSyncAt      DateTime?
  settings        Json?
  pairedAt        DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId])
  @@index([deviceType])
  @@map("devices")
}

model FamilyGroup {
  id          String         @id @default(uuid())
  ownerUserId String
  owner       User           @relation("FamilyOwner", fields: [ownerUserId], references: [id])
  name        String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  members     FamilyMember[]

  @@index([ownerUserId])
  @@map("family_groups")
}

model FamilyMember {
  id              String      @id @default(uuid())
  familyGroupId   String
  familyGroup     FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  memberUserId    String
  member          User        @relation("FamilyMemberUser", fields: [memberUserId], references: [id])
  relationship    String
  // NOTE: permissionLevel (String) is REMOVED — replaced with permissions (Json)
  permissions     Json?       // SharePermission object; if null → default safe permissions apply
  silentHoursStart String?    // "22:00" format
  silentHoursEnd   String?    // "07:00" format
  isActive        Boolean     @default(true)
  inviteAccepted  Boolean     @default(false)
  inviteToken     String?     @unique
  inviteExpiresAt DateTime?   // invite token expiry (48h from creation)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([familyGroupId, memberUserId])
  @@index([memberUserId])
  @@index([inviteToken])
  @@map("family_members")
}

model Product {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String
  deviceType  DeviceType?  // null = works with both
  category    String
  price       Float
  stock       Int        @default(0)
  images      String[]
  features    String[]
  sizes       String[]
  colors      String[]
  isActive    Boolean    @default(true)
  isFeatured  Boolean    @default(false)
  rating      Float?
  reviewCount Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  orderItems  OrderItem[]

  @@index([deviceType])
  @@index([category])
  @@map("products")
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          OrderStatus @default(PENDING)
  totalAmount     Float
  discountAmount  Float       @default(0)
  promoCode       String?
  shippingAddress Json
  paymentId       String?
  paymentMethod   String?
  trackingNumber  String?
  notes           String?
  ringSize        String?    // for SmartRing orders
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  size      String?
  color     String?

  @@map("order_items")
}

model Alert {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertType   String
  severity    AlertSeverity
  message     String
  metadata    Json?
  isRead      Boolean       @default(false)
  isAcknowledged Boolean    @default(false)
  acknowledgedAt DateTime?
  createdAt   DateTime      @default(now())

  @@index([userId])
  @@index([severity])
  @@index([createdAt])
  @@map("alerts")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  sentAt    DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// Audit log — every Kafka event that was produced
model KafkaEventLog {
  id        String   @id @default(uuid())
  topic     String
  key       String?
  payload   Json
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  producedAt DateTime @default(now())

  @@index([topic])
  @@index([userId])
  @@index([producedAt])
  @@map("kafka_event_logs")
}

// ── AI Coach ──────────────────────────────────────────────────────────────────

model AiInsight {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      String                    // 'sleep' | 'heart' | 'activity' | 'recovery' | 'general'
  title         String
  body          String
  priority      String                    // 'high' | 'medium' | 'low'
  iconEmoji     String
  deepLinkRoute String?
  actionItems   String[]
  correlationNote String?
  // Snapshot of vitals used to generate this insight (for audit/debugging)
  vitalSnapshot Json?
  // Snapshot of user profile used
  profileSnapshot Json?
  isCurrent     Boolean  @default(true)   // false when superseded by new generation
  createdAt     DateTime @default(now())

  interactions  AiInsightInteraction[]

  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@map("ai_insights")
}

model AiInsightInteraction {
  id        String   @id @default(uuid())
  insightId String
  insight   AiInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'thumbs_up' | 'thumbs_down' | 'click'
  createdAt DateTime @default(now())

  @@unique([insightId, userId, type])
  @@index([insightId])
  @@index([userId])
  @@map("ai_insight_interactions")
}

model AiInsightCache {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyBrief      String
  insights        Json                    // serialised AiInsight[]
  todayActions    String[]
  readinessMessage String
  workoutSuggestion Json
  generatedAt     DateTime @default(now())
  expiresAt       DateTime               // generatedAt + 24h

  @@map("ai_insight_cache")
}

model AiQuestion {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  askedAt   DateTime @default(now())

  @@index([userId])
  @@map("ai_questions")
}

// ── Workout / Fitness Plan ────────────────────────────────────────────────────

model WorkoutPlan {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  goal          String                    // 'strength' | 'endurance' | 'weight_loss' | 'general'
  durationWeeks Int
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean       @default(true)
  isAiGenerated Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  days          WorkoutDay[]
  logs          WorkoutLog[]

  @@index([userId])
  @@index([isActive])
  @@map("workout_plans")
}

model WorkoutDay {
  id          String        @id @default(uuid())
  planId      String
  plan        WorkoutPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  dayOfWeek   Int           // 1=Monday, 7=Sunday
  label       String        // "Push Day", "Rest Day", "Cardio"
  isRestDay   Boolean       @default(false)
  notes       String?
  sortOrder   Int           @default(0)

  exercises   WorkoutExercise[]
  logs        WorkoutLog[]

  @@index([planId])
  @@map("workout_days")
}

model WorkoutExercise {
  id              String     @id @default(uuid())
  dayId           String
  day             WorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exerciseId      String
  exercise        Exercise   @relation(fields: [exerciseId], references: [id])
  sets            Int?
  reps            Int?
  durationSeconds Int?
  weightKg        Float?
  restSeconds     Int?
  notes           String?
  sortOrder       Int        @default(0)

  @@index([dayId])
  @@map("workout_exercises")
}

model Exercise {
  id          String   @id @default(uuid())
  name        String
  category    String   // 'strength' | 'cardio' | 'flexibility' | 'balance'
  muscleGroup String?  // 'chest' | 'back' | 'legs' | 'shoulders' | 'arms' | 'core'
  equipment   String?  // 'barbell' | 'dumbbell' | 'bodyweight' | 'machine' | 'cable'
  description String?
  videoUrl    String?
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())

  workoutExercises WorkoutExercise[]

  @@index([category])
  @@index([muscleGroup])
  @@map("exercises")
}

model WorkoutLog {
  id               String      @id @default(uuid())
  planId           String
  plan             WorkoutPlan @relation(fields: [planId], references: [id])
  dayId            String
  day              WorkoutDay  @relation(fields: [dayId], references: [id])
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime
  completed        Boolean     @default(true)
  durationMinutes  Int?
  perceivedEffort  Float?      // 1–10 RPE
  notes            String?
  avgHeartRate     Float?
  peakHeartRate    Float?
  caloriesBurned   Float?
  strain           Float?      // band-specific
  exerciseLogs     Json?       // array of { exerciseId, sets: [{reps, weightKg, completed}] }
  createdAt        DateTime    @default(now())

  @@index([userId])
  @@index([planId])
  @@index([date])
  @@map("workout_logs")
}

// ── Meditation ────────────────────────────────────────────────────────────────

model MeditationSession {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  patternId       String                   // 'box' | '478' | 'wim_hof' | 'co2_tolerance' | 'custom'
  patternName     String
  category        String                   // 'relaxation' | 'energising' | 'focus' | 'breath_hold'
  durationSeconds Int                      // actual session length
  cyclesCompleted Int
  // HRV before/after (if device connected)
  hrvBefore       Float?
  hrvAfter        Float?
  hrvDelta        Float?                   // positive = improved
  // Breath hold specific
  breathHoldSeconds Int?                   // max hold time in this session
  breathHoldCount   Int?                   // how many holds in Wim Hof
  notes           String?
  completedAt     DateTime @default(now())

  @@index([userId])
  @@index([completedAt])
  @@map("meditation_sessions")
}

// ── Broadcast ─────────────────────────────────────────────────────────────────

model BroadcastMessage {
  id            String   @id @default(uuid())
  title         String
  body          String
  imageUrl      String?
  type          String   @default("info")  // 'info' | 'warning' | 'update' | 'maintenance'
  isDismissable Boolean  @default(true)
  actionLabel   String?
  actionUrl     String?
  targetSegment String   @default("all")  // 'all' | 'ring_users' | 'band_users'
  sentAt        DateTime @default(now())
  sentByAdminId String
  sentByAdmin   User     @relation(fields: [sentByAdminId], references: [id])
  recipientCount Int     @default(0)      // populated after dispatch

  @@index([sentAt])
  @@map("broadcast_messages")
}

// ── Firmware ──────────────────────────────────────────────────────────────────

model FirmwareVersion {
  id           String     @id @default(uuid())
  deviceType   DeviceType
  version      String     // "2.1.5"
  s3Key        String     // path in S3 bucket
  releaseNotes String
  isLatest     Boolean    @default(true)
  releasedAt   DateTime   @default(now())

  @@index([deviceType, isLatest])
  @@map("firmware_versions")
}

// ── Support ──────────────────────────────────────────────────────────────────

model SupportTicket {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  status      TicketStatus @default(OPEN)
  priority    String       @default("medium") // 'low' | 'medium' | 'high' | 'urgent'
  category    String       // 'technical' | 'billing' | 'general' | 'device'
  messages    Json         // Array of { sender: 'user' | 'admin', text: string, timestamp: string }
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}
